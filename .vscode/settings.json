{
  "python.defaultInterpreterPath": "${workspaceFolder}/eval/.venv/Scripts/python.exe",
  "python.analysis.extraPaths": ["eval/src"],
  "python.analysis.diagnosticMode": "workspace",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "files.eol": "\n",
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.mypy_cache": true
  }
}
